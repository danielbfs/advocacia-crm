# ============================================================
# Open Clinic AI — Configuração de Ambiente (AWS Lightsail + Neon DB)
#
# 1. Copie este arquivo: cp .env.lightsail.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA versione o arquivo .env (já está no .gitignore)
# ============================================================

# ── DOMÍNIO & SSL ───────────────────────────────────────────
# Seu domínio apontando para o IP Estático do Lightsail (ex: clinica.seudominio.com)
DOMAIN=clinica.seudominio.com
# E-mail para geração de certificados SSL via Let's Encrypt
ACME_EMAIL=seu-email@gmail.com

# ── BANCO DE DADOS (NEON DB) ─────────────────────────────────
# IMPORTANTE: Use a URI com o driver asyncpg (postgresql+asyncpg://) para o backend
DATABASE_URL=postgresql+asyncpg://user:password@ep-something.us-east-2.aws.neon.tech/openclinic?sslmode=require

# IMPORTANTE: Use a URI padrão (postgresql://) para a Evolution API (WhatsApp)
# Dica: Crie um banco separado chamado 'evolution' no console da Neon
EVOLUTION_DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/evolution?sslmode=require

# ── SEGURANÇA ────────────────────────────────────────────────
# Chave secreta para tokens JWT (mínimo 64 caracteres) — gere com: openssl rand -hex 32
SECRET_KEY=

# Chave da API da Evolution (WhatsApp) — gere com: openssl rand -hex 24
EVOLUTION_API_KEY=openclinic-evo-key

# ── TELEGRAM ─────────────────────────────────────────────────
# Token do bot criado via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# ── AI / LLM ─────────────────────────────────────────────────
# API Key da OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (Opcional) API Key do DeepSeek
DEEPSEEK_API_KEY=

# ── CLÍNICA ──────────────────────────────────────────────────
# Fuso horário padrão
CLINIC_TIMEZONE=America/Sao_Paulo
# SLA de retorno para leads em horas
CLINIC_SLA_HOURS=2

# ── API KEY PARA WEBHOOKS EXTERNOS ───────────────────────────
# Usado para receber leads de formulários, Google Ads e Meta Ads
# Gere com: openssl rand -hex 24
LEADS_WEBHOOK_API_KEY=
